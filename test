import serial
import time
import os
import threading
import sys

# --- CONFIGURATION ---
SERIAL_PORT = 'COM9'   # Check your Arduino IDE for the correct port
BAUD_RATE = 921600     # Must match Arduino code
SAVE_FOLDER = "captured_frames"

# Global flag to stop the thread cleanly
running = True

def read_exact_bytes(ser, size):
    """Helper to ensure we get exactly the number of bytes we expect"""
    data = bytearray()
    while len(data) < size:
        packet = ser.read(size - len(data))
        if not packet:
            return None 
        data.extend(packet)
    return data

def serial_listener(ser):
    """Background thread that listens for images or text from ESP32"""
    global running
    frame_count = 0
    
    # Create folder if needed
    if not os.path.exists(SAVE_FOLDER):
        os.makedirs(SAVE_FOLDER)

    print(f"\n[Listener] Listening on {SERIAL_PORT}... (Images will save to '{SAVE_FOLDER}')")

    while running:
        try:
            if ser.in_waiting > 0:
                # Read a line
                line = ser.readline()

                # CASE 1: It's an Image Header (SIZE:12345)
                if line.startswith(b"SIZE:"):
                    try:
                        size_str = line.split(b':')[1].strip()
                        image_size = int(size_str)
                        
                        print(f"\n[Incoming] Capturing Frame {frame_count} ({image_size} bytes)... ", end="")
                        
                        image_data = read_exact_bytes(ser, image_size)
                        
                        if image_data:
                            filename = os.path.join(SAVE_FOLDER, f"img_{int(time.time())}_{frame_count}.jpg")
                            with open(filename, "wb") as f:
                                f.write(image_data)
                            print(f"Saved: {filename}")
                            frame_count += 1
                        else:
                            print("Error: Incomplete data.")
                    except ValueError:
                        print(f"[Error] Bad Size Header: {line}")

                # CASE 2: It's just text (Debug messages like SYSTEM_READY)
                else:
                    try:
                        text = line.decode('utf-8', errors='ignore').strip()
                        if text:
                            print(f"[ESP32 Says]: {text}")
                    except:
                        pass
            else:
                # Sleep briefly to not hog CPU
                time.sleep(0.01)
                
        except Exception as e:
            print(f"Serial Error: {e}")
            running = False
            break

def main():
    global running
    
    try:
        ser = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=1)
        # Wait a moment for the reboot
        time.sleep(0.5)
    except Exception as e:
        print(f"Could not open port {SERIAL_PORT}: {e}")
        return

    # Start the background listener thread
    t = threading.Thread(target=serial_listener, args=(ser,))
    t.start()

    print("-" * 50)
    print("COMMAND MENU:")
    print(" S = Start Streaming")
    print(" C = Capture Single Photo")
    print(" E = End Streaming")
    print(" Q = Quit Python Script")
    print("-" * 50)

    # Main loop: waits for your keyboard input
    try:
        while running:
            cmd = input().upper() # Blocks here waiting for you to type
            
            if cmd == 'Q':
                print("Quitting...")
                ser.write(b'E') # Try to stop stream first
                running = False
                break
            elif cmd in ['S', 'C', 'E']:
                print(f"Sending command: {cmd}...")
                ser.write(cmd.encode())
            else:
                print("Unknown command. Use S, C, E, or Q.")
            
            time.sleep(0.5) # Give ESP32 time to react

    except KeyboardInterrupt:
        running = False
        
    print("Closing connection...")
    ser.close()
    t.join() # Wait for thread to close
    print("Done.")

if __name__ == "__main__":
    main()
