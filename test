import serial
import time
import os
import threading
import sys
import cv2            # The Computer Vision library
import numpy as np    # The Math library for image decoding

# --- CONFIGURATION ---
SERIAL_PORT = 'COM9'   # Your specific COM port
BAUD_RATE = 921600     # Match your Arduino code (115200 or 921600)
SAVE_FOLDER = "captured_frames"

# Global flag to stop the thread cleanly
running = True

def read_exact_bytes(ser, size):
    """Helper to ensure we get exactly the number of bytes we expect"""
    data = bytearray()
    while len(data) < size:
        packet = ser.read(size - len(data))
        if not packet:
            return None 
        data.extend(packet)
    return data

def serial_listener(ser):
    """Background thread that listens for images or text from ESP32"""
    global running
    frame_count = 0
    
    # Create folder if needed
    if not os.path.exists(SAVE_FOLDER):
        os.makedirs(SAVE_FOLDER)

    print(f"\n[Listener] Listening on {SERIAL_PORT}...")

    while running:
        try:
            if ser.in_waiting > 0:
                line = ser.readline()

                # CASE 1: It's an Image Header (SIZE:12345)
                if line.startswith(b"SIZE:"):
                    try:
                        size_str = line.split(b':')[1].strip()
                        image_size = int(size_str)
                        
                        print(f"Frame: {frame_count} ({image_size} bytes)... ", end="")
                        
                        # 1. Read the raw bytes
                        image_data = read_exact_bytes(ser, image_size)
                        
                        if image_data:
                            # 2. SAVE IT TO DISK (Optional, keep if you want a record)
                            filename = os.path.join(SAVE_FOLDER, f"frame_{frame_count}.jpg")
                            with open(filename, "wb") as f:
                                f.write(image_data)
                            
                            # 3. DISPLAY IT ON SCREEN (The new part!)
                            # Convert raw bytes into a numpy array
                            nparr = np.frombuffer(image_data, np.uint8)
                            # Decode the JPEG data into an image
                            img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)

                            # Check if decode worked (sometimes bytes get corrupted)
                            if img is not None:
                                cv2.imshow('ESP32 Live Stream', img)
                                # Wait 1ms to allow the window to redraw
                                cv2.waitKey(1) 
                                print("Displayed.")
                            else:
                                print("Decode Error.")

                            frame_count += 1
                        else:
                            print("Incomplete data.")
                    except ValueError:
                        print(f"Bad Header: {line}")

                # CASE 2: Text Debug
                else:
                    try:
                        text = line.decode('utf-8', errors='ignore').strip()
                        if text:
                            print(f"[ESP32]: {text}")
                    except:
                        pass
            else:
                time.sleep(0.005) # Check very frequently for smooth video
                
        except Exception as e:
            print(f"Serial Error: {e}")
            running = False
            break

def main():
    global running
    
    try:
        ser = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=1)
        ser.dtr = False 
        ser.rts = False 
        time.sleep(0.5)
    except Exception as e:
        print(f"Could not open port {SERIAL_PORT}: {e}")
        return

    # Start the background listener
    t = threading.Thread(target=serial_listener, args=(ser,))
    t.start()

    print("-" * 50)
    print("LIVE STREAM CONTROL:")
    print(" S = Start Video Stream")
    print(" E = Stop Video Stream")
    print(" C = Capture Single Frame")
    print(" Q = Quit")
    print("-" * 50)

    try:
        while running:
            # We use input() to pause the main thread waiting for commands
            cmd = input().upper() 
            
            if cmd == 'Q':
                ser.write(b'E')
                running = False
                break
            elif cmd in ['S', 'C', 'E']:
                ser.write(cmd.encode())
            
    except KeyboardInterrupt:
        running = False
        
    print("Closing...")
    ser.close()
    cv2.destroyAllWindows() # Close the video window
    t.join()
    print("Done.")

if __name__ == "__main__":
    main()
