    dayOfWeek: 2,         // Tuesday
    hour: 13,
    minute: 0,
    timezone: 'America/New_York'
  },
  ECBASSETSW: {
    frequency: 'weekly',
    dayOfWeek: 2,         // Tuesday
    hour: 10,
    minute: 0,
    timezone: 'Europe/Berlin'
  },
  JPNASSETS: {
